# Copy this file to .env and fill in your values.
# DO NOT commit .env to GitHub — it contains secrets.

# ---- MySQL ----
DB_URL=jdbc:mysql://localhost:3306/dressshop
DB_USERNAME=root
DB_PASSWORD=your_db_password

# ---- Admin credentials ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password
# Long random string — used as a Bearer token for admin API calls
ADMIN_TOKEN=replace_with_a_long_random_secret

# ---- JWT (customer auth) ----
# Must be at least 32 characters for HMAC-SHA256
JWT_SECRET=replace_with_a_long_random_jwt_secret_at_least_32_chars

# ---- Server ----
SERVER_BASE_URL=http://localhost:8080

# ---- CORS ----
# Frontend origin — no trailing slash
CORS_ALLOWED_ORIGIN=http://localhost:5172

# ---- File uploads ----
UPLOAD_DIR=./uploads
