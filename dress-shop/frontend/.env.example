# Copy this file to .env and fill in your values

# Your Spring Boot backend URL (no trailing slash)
VITE_API_URL=http://localhost:8080/api

# Shop owner's WhatsApp number in international format, no + or spaces
# Example: 91XXXXXXXXXX
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX

# Shop display name
VITE_SHOP_NAME=U99
